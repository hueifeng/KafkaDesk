{
  "name": "traceforge",
  "private": true,
  "version": "0.1.0",
  "description": "Desktop-first event-stream debugging workbench shell for KafkaDesk.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "typecheck": "tsc -b",
    "lint": "eslint src vite.config.ts vitest.config.ts --max-warnings=0",
    "test:frontend": "vitest run --config vitest.config.ts",
    "test:frontend:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml",
    "test": "npm run test:frontend && npm run test:rust",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml && cargo test --manifest-path src-tauri/Cargo.toml",
    "check:frontend": "npm run lint && npm run typecheck && npm run test:frontend && vite build",
    "smoke": "npm run lint && npm run typecheck && npm run test:frontend",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.66.0",
    "@tauri-apps/api": "^2.8.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.8.0",
    "@types/node": "^22.10.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^10.2.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.16",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.58.1",
    "vite": "^6.0.5",
    "vitest": "^4.1.4"
  }
}
